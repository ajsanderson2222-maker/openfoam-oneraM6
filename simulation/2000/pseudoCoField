FoamFile
{
    format      ascii;
    class       volScalarField;
    location    "2000";
    object      pseudoCoField;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [];

internalField   uniform 20;

boundaryField
{
    intPatch
    {
        type            calculated;
        value           nonuniform List<scalar> 0();
    }
    wing
    {
        type            calculated;
        value           uniform 20;
    }
    symm
    {
        type            symmetry;
    }
    farfield
    {
        type            calculated;
        value           uniform 20;
    }
}


